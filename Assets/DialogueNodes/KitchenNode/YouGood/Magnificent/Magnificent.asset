  m_Name: Magnificent
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  defaultText: 'Awwww you''re too sweet! You''re the magnificent one! When I''m with
    you I get all bubbly... like a pufferfish! '
  conditionalTexts: []
  locationImage: {fileID: -6762806206646994688, guid: 5a312ca6513adf944b2510ddbd8ab41a, type: 3}
  playerSprite: {fileID: 6848535425815238608, guid: 253ca898bb23d1f4fb445517cd4d7086, type: 3}
