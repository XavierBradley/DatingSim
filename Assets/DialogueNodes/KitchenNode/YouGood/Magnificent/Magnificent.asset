  options:
  - optionText: You're about as toxic to be around as a pufferfish too.
    nextNode: {fileID: 11400000, guid: 11bb459904e4a4a45aa0d14786d0a45c, type: 2}
    choiceTrigger:
      text: You're about as toxic to be around as a pufferfish too.
      requiredItem: {fileID: 0}
      setsFlag: 
      changesPhase: 0
      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: 'Aww, I feel all bubbly and happy too! I always swell up with joy
      whenever I see you! '
    nextNode: {fileID: 11400000, guid: 23142e6c0fbce2c4d8e9454595ce822a, type: 2}
    choiceTrigger:
      text: You're not the only one that swells up when we're together...
      requiredItem: {fileID: 0}
      setsFlag: 
      changesPhase: 0
      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: 'You''re always bubbly... but I suppose if I have a part to play
      in that, then I can take pride in that! '
    nextNode: {fileID: 11400000, guid: 80b14715c6932304cb5bcd67c26817ab, type: 2}
    choiceTrigger:
      text: 'You''re always bubbly... but I suppose if I have a part to play in that,
