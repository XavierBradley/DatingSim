  m_Name: Juicy
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  defaultText: 'You''re always so sweet to me! I definitely gotta find some way to
    pay you back... you interested in surfing lessons? '
  conditionalTexts: []
  locationImage: {fileID: -6762806206646994688, guid: 5a312ca6513adf944b2510ddbd8ab41a, type: 3}
  playerSprite: {fileID: 6848535425815238608, guid: 253ca898bb23d1f4fb445517cd4d7086, type: 3}
  npcSprite: {fileID: 7310064867776009774, guid: ffee90d6d34f5cd44b9ca5b729384c27, type: 3}
  options:
  - optionText: I can think of plenty of ways you could pay me back... how about
      we start with a kiss?
    nextNode: {fileID: 11400000, guid: 6645c31c95feed244adf6af3735a692a, type: 2}
    choiceTrigger:
      text: I can think of plenty of ways you could pay me back... how about we start
        with a kiss?
      requiredItem: {fileID: 0}
      setsFlag: 
      changesPhase: 0
      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: As long as they involve you holding me steady while you teach me
      I could get behind some surfing lessons
    nextNode: {fileID: 11400000, guid: e108d3fea6c3097478677f40e0495b54, type: 2}
    choiceTrigger:
      text: As long as they involve you holding me steady while you teach me I could
        get behind some surfing lessons
      requiredItem: {fileID: 0}
      setsFlag: 
      changesPhase: 0
      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: I think that learning to surf with you is about the last thing I
      want to do
    nextNode: {fileID: 0}
    choiceTrigger:
      text: I think that learning to surf with you is about the last thing I want
        to do
      requiredItem: {fileID: 0}
      setsFlag: 
      changesPhase: 0
      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: 'Could be fun! For now though, you ready to make some sandwiches? '
