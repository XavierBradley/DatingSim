  m_Name: Mouth
  m_EditorClassIdentifier: Assembly-CSharp::DialogueNode
  defaultText: Damn dude! You don't need to go baring your Jaws at me! Is it really
    such a crime for a muchacho to be hungry?! I guess I'll just shut my gaping maw
    and make a sandwich...
  conditionalTexts: []
  locationImage: {fileID: 3217450130235862456, guid: 7fb2684725d765c41935f660ab49e3f7, type: 3}
