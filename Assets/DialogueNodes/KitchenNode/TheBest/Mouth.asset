  npcSprite: {fileID: 7310064867776009774, guid: 54f4007506920af44bcc6b7374d1e5c3, type: 3}
  options:
  - optionText: Sorry... that came out a lot harsher than I meant for it to! Let
      me make you a sandwich to make it up to you!
    nextNode: {fileID: 0}
    choiceTrigger:
      text: Sorry... that came out a lot harsher than I meant for it to! Let me make
