  npcSprite: {fileID: 7310064867776009774, guid: ffee90d6d34f5cd44b9ca5b729384c27, type: 3}
  options:
  - optionText: 'Of course I feel special about you... I''ve just been too nervous
      to talk about it... but you''re right, we can discuss that later! '
    nextNode: {fileID: 0}
    choiceTrigger:
      text: 'Of course I feel special about you... I''ve just been too nervous to
