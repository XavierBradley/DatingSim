      setsFlag: 
      changesPhase: 0
      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: 'Is that so? Sounds to me like you''ve got room for all kinds of
      fun activies! '
    nextNode: {fileID: 11400000, guid: 2b144bc771d57c842b73b141a0bc9be9, type: 2}
