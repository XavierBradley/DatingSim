  npcSprite: {fileID: 7310064867776009774, guid: 54f4007506920af44bcc6b7374d1e5c3, type: 3}
  options:
  - optionText: I have to disagree... being with you is the greatest treasure of
      all! I almost don't want to find the blankets...
