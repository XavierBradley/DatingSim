      changesPhase: 0
      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: 'I''ve been enjoying it as well! I''d rather it not end, buuuuut
      we''re here for a reason, and it''s about time we do something about it! '
    nextNode: {fileID: 0}
    choiceTrigger:
      text: 'I''ve been enjoying it as well! I''d rather it not end, buuuuut we''re
