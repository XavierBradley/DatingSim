      newPhase: 0
    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: It's an amazing moment... one that I wish could last forever... but
      alas the power calls
    nextNode: {fileID: 0}
    choiceTrigger:
      text: It's an amazing moment... one that I wish could last forever... but alas
