    requiredFlags: []
    blockedFlags: []
    usePhaseRequirement: 0
    requiredPhase: 0
  - optionText: That doesn't particularly sound like a complaint... does that mean
      you want me to keep teasing?
    nextNode: {fileID: 11400000, guid: bf91a9d0e2c52be49a095df661bb1d2f, type: 2}
    choiceTrigger:
      text: That doesn't particularly sound like a complete... does that mean you
